FROM node:20.20.2-alpine3.23 As builder
RUN mkdir /app
WORKDIR /app
COPY package.json .
COPY server.js .
RUN npm install

FROM node:20.20.2-alpine3.23
WORKDIR /app
EXPOSE 8080
COPY --from=builder /app .
RUN addgroup -S roboshop && adduser -S roboshop -G roboshop
USER roboshop
CMD ["server.js"]
ENTRYPOINT ["node"]